{
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "predev": "node ./scripts/ensure-env.js",
    "dev": "npm run generate-version && next dev --turbo",
    "build": "npm run fetch-avatar && npm run generate-version && npm run build-cv && next build",
    "build-only": "npm run generate-version && npm run build-cv && next build",
    "analyze": "ANALYZE=true npm run build-only",
    "start": "next start",
    "lint": "biome lint",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit --project tests/tsconfig.json",
    "fetch-avatar": "node ./scripts/fetch-avatar.js",
    "generate-version": "node ./scripts/generate-version.js",
    "build-cv": "./scripts/build-cv.sh",
    "update-cv": "node ./scripts/generate-latex.js && npm run generate-version && npm run build-cv && echo '✅ CV updated! Check git status for changes to commit.'",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:vercel": "node ./scripts/run-e2e-vercel.js"
  },
  "dependencies": {
    "@vercel/analytics": "^1.1.3",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.4.2",
    "linkedom": "^0.18.12",
    "mermaid": "^11.9.0",
    "next": "^16.2.10",
    "postgres": "^3.4.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "sugar-high": "^0.9.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.3",
    "avatar-fetcher": "^0.1.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "unpdf": "^1.6.2",
    "vitest": "^3.2.4"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "overrides": {
    "postcss": "^8.5.15",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.0"
  }
}
